{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowImportingTsExtensions": true,
    "jsx": "react-jsx",
    "types": ["node"],
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true
  },
  "include": ["src", "vite.config.ts"]
}

